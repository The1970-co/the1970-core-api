  dailyBudget     Decimal?  @db.Decimal(18, 2)
  lifetimeBudget  Decimal?  @db.Decimal(18, 2)
  startTime       DateTime?
  stopTime        DateTime?
  rawJson         Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account  MetaAdAccount        @relation(fields: [metaAccountId], references: [metaAccountId], onDelete: Cascade)
  adSets   MetaAdSet[]
  ads      MetaAd[]
  insights MetaAdInsightDaily[]

  @@index([metaAccountId])
  @@index([status])
  @@index([effectiveStatus])
  @@index([lastSyncedAt])
}

model MetaAdSet {
  id               String    @id @default(cuid())
  metaAccountId    String
  metaCampaignId   String?
  metaAdSetId      String    @unique
  name             String?
  status           String?
  effectiveStatus  String?
  optimizationGoal String?
  billingEvent     String?
  bidStrategy      String?
  dailyBudget      Decimal?  @db.Decimal(18, 2)
  lifetimeBudget   Decimal?  @db.Decimal(18, 2)
  startTime        DateTime?
  endTime          DateTime?
  targetingJson    Json?
  rawJson          Json?
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  account  MetaAdAccount        @relation(fields: [metaAccountId], references: [metaAccountId], onDelete: Cascade)
  campaign MetaCampaign?        @relation(fields: [metaCampaignId], references: [metaCampaignId], onDelete: SetNull)
  ads      MetaAd[]
  insights MetaAdInsightDaily[]

  @@index([metaAccountId])
  @@index([metaCampaignId])
  @@index([status])
  @@index([effectiveStatus])
  @@index([lastSyncedAt])
}

model MetaAd {
  id                   String    @id @default(cuid())
  metaAccountId        String
  metaCampaignId       String?
  metaAdSetId          String?
  metaAdId             String    @unique
  metaCreativeId       String?
  name                 String?
  status               String?
  effectiveStatus      String?
  previewShareableLink String?
  thumbnailUrl         String?
  imageUrl             String?
  videoId              String?
  postId               String?
  pageId               String?
  callToActionType     String?
  creativeJson         Json?
  rawJson              Json?
  lastSyncedAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  account  MetaAdAccount        @relation(fields: [metaAccountId], references: [metaAccountId], onDelete: Cascade)
  campaign MetaCampaign?        @relation(fields: [metaCampaignId], references: [metaCampaignId], onDelete: SetNull)
  adSet    MetaAdSet?           @relation(fields: [metaAdSetId], references: [metaAdSetId], onDelete: SetNull)
  insights MetaAdInsightDaily[]

  @@index([metaAccountId])
  @@index([metaCampaignId])
  @@index([metaAdSetId])
  @@index([metaCreativeId])
  @@index([status])
  @@index([effectiveStatus])
  @@index([lastSyncedAt])
