  level            String
  dateStart        DateTime
  dateStop         DateTime
  metaCampaignId   String?
  metaAdSetId      String?
  metaAdId         String?
  campaignName     String?
  adSetName        String?
  adName           String?
  spend            Decimal  @default(0) @db.Decimal(18, 2)
  impressions      Int      @default(0)
  reach            Int      @default(0)
  clicks           Int      @default(0)
  inlineLinkClicks Int      @default(0)
  cpc              Decimal  @default(0) @db.Decimal(18, 4)
  cpm              Decimal  @default(0) @db.Decimal(18, 4)
  ctr              Decimal  @default(0) @db.Decimal(18, 4)
  purchases        Int      @default(0)
  purchaseValue    Decimal  @default(0) @db.Decimal(18, 2)
  costPerPurchase  Decimal  @default(0) @db.Decimal(18, 4)
  roas             Decimal  @default(0) @db.Decimal(18, 4)
  actionsJson      Json?
  actionValuesJson Json?
  rawJson          Json?
