  adSets    MetaAdSet[]
  ads       MetaAd[]
  insights  MetaAdInsightDaily[]

  @@index([accountStatus])
  @@index([lastSyncedAt])
}

model MetaCampaign {
  id              String    @id @default(cuid())
  metaAccountId   String
  metaCampaignId  String    @unique
  name            String?
  status          String?
  effectiveStatus String?
  objective       String?
