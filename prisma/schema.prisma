model MetaAdAccount {
  id            String    @id @default(cuid())
  metaAccountId String    @unique
  accountId     String?
  name          String?
  currency      String?
  timezoneName  String?
  accountStatus String?
  businessId    String?
  businessName  String?
  rawJson       Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

