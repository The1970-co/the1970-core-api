generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id                 String              @id @default(cuid())
  fullName           String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(STAFF)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  totpEnabled        Boolean             @default(false)
  totpSecret         String?
  auditLogs          AuditLog[]
  inventoryMovements InventoryMovement[]
  purchaseReceipts   PurchaseReceipt[]
}

model Product {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  category             String?
  categoryId           String?
  productType          String?
  brand                String?
  weight               Float?
  imageUrl             String?
  description          String?
  status               ProductStatus         @default(DRAFT)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  categoryRel          Category?             @relation(fields: [categoryId], references: [id])
  variants             ProductVariant[]
  purchaseReceiptItems PurchaseReceiptItem[]
  promotionProducts    PromotionProduct[]

  @@index([categoryId])
}

model ProductVariant {
  id                   String                   @id @default(cuid())
  productId            String
  sku                  String                   @unique
  color                String?
  size                 String?
  price                Decimal                  @db.Decimal(14, 2)
  compareAtPrice       Decimal?                 @db.Decimal(14, 2)
  costPrice            Decimal?                 @db.Decimal(14, 2)
  imageUrl             String?
  status               VariantStatus            @default(ACTIVE)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  inventoryItems       InventoryItem[]
  movements            InventoryMovement[]
  orderItems           OrderItem[]
  product              Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseReceiptItems PurchaseReceiptItem[]
  stockTransferItems   StockTransferItem[]
  locations            ProductVariantLocation[]
}

model InventoryItem {
  id           String         @id @default(cuid())
  variantId    String
  branchId     String
  availableQty Int            @default(0)
  reservedQty  Int            @default(0)
  incomingQty  Int            @default(0)
  updatedAt    DateTime       @updatedAt
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, branchId])
  @@index([branchId])
  @@index([variantId])
}

model InventoryMovement {
  id String @id @default(cuid())

  variantId String
  branchId  String

  type InventoryMovementType
  qty  Int

  beforeQty Int?
  afterQty  Int?

  note    String?
  refType String?
  refId   String?

  createdById String?
  createdAt   DateTime @default(now())

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy AdminUser?     @relation(fields: [createdById], references: [id])

  @@index([variantId])
  @@index([branchId])
  @@index([type])
  @@index([refType, refId])
  @@index([createdAt])
}

model Customer {
  id                     String            @id @default(cuid())
  legacyCode             String?
  fullName               String
  phone                  String?
  email                  String?
  source                 String?
  customerGroup          String?
  gender                 String?
  birthDate              DateTime?
  points                 Int               @default(0)
  totalOrders            Int               @default(0)
  totalSpent             Decimal           @default(0) @db.Decimal(14, 2)
  lastOrderAt            DateTime?
  defaultDiscountPercent Decimal?          @db.Decimal(5, 2)
  pricePolicyName        String?
  customerNote           String?
  lastImportedAt         DateTime?
  lastImportedSource     String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  addresses              CustomerAddress[]
  orders                 Order[]

  @@index([phone])
  @@index([email])
  @@index([legacyCode])
  @@index([customerGroup])
}

model CustomerAddress {
  id            String   @id @default(cuid())
  customerId    String
  label         String?
  recipientName String?
  phone         String?
  email         String?
  addressLine1  String
  addressLine2  String?
  ward          String?
  district      String?
  city          String?
  province      String?
  country       String?  @default("Vietnam")
  postalCode    String?
  isDefault     Boolean  @default(false)
  ghnDistrictId Int?
  ghnWardCode   String?
  ghnWardIdV2   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([customerId])
  @@index([province])
  @@index([ward])
  @@index([ghnDistrictId])
  @@index([ghnWardCode])
}

model Order {
  id                    String                  @id @default(cuid())
  orderCode             String                  @unique
  salesChannel          SalesChannel
  customerId            String?
  customerName          String?
  customerPhone         String?
  branchId              String?
  currency              String                  @default("VND")
  totalAmount           Decimal                 @default(0) @db.Decimal(14, 2)
  discountAmount        Decimal                 @default(0) @db.Decimal(14, 2)
  shippingFee           Decimal                 @default(0) @db.Decimal(14, 2)
  finalAmount           Decimal                 @default(0) @db.Decimal(14, 2)
  paymentStatus         PaymentStatus           @default(UNPAID)
  fulfillmentStatus     FulfillmentStatus       @default(UNFULFILLED)
  status                OrderStatus             @default(NEW)
  note                  String?
  source                String?
  customerAddressId     String?
  shippingRecipientName String?
  shippingPhone         String?
  shippingEmail         String?
  shippingAddressLabel  String?
  shippingAddressLine1  String?
  shippingAddressLine2  String?
  shippingWard          String?
  shippingDistrict      String?
  shippingCity          String?
  shippingProvince      String?
  shippingCountry       String?
  shippingPostalCode    String?
  shippingGhnDistrictId Int?
  shippingGhnWardCode   String?
  shippingGhnWardIdV2   String?
  billingRecipientName  String?
  billingPhone          String?
  billingEmail          String?
  billingAddressLabel   String?
  billingAddressLine1   String?
  billingAddressLine2   String?
  billingWard           String?
  billingDistrict       String?
  billingCity           String?
  billingProvince       String?
  billingCountry        String?
  billingPostalCode     String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  createdByStaffId      String?
  createdByStaffName    String?
  soldAt                DateTime                @default(now())
  isPartialDelivery     Boolean                 @default(false)
  partialReason         String?
  customerAddress       CustomerAddress?        @relation(fields: [customerAddressId], references: [id])
  customer              Customer?               @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  partialDeliveries     PartialDeliveryRecord[]
  payments              Payment[]
  shipment              Shipment?

  @@index([customerPhone])
  @@index([branchId])
  @@index([customerId])
  @@index([customerAddressId])
  @@index([shippingProvince])
  @@index([shippingWard])
  @@index([shippingGhnDistrictId])
  @@index([shippingGhnWardCode])
  @@index([status])
  @@index([createdByStaffId])
  @@index([soldAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  variantId   String?
  sku         String
  productName String
  color       String?
  size        String?
  qty         Int
  unitPrice   Decimal         @db.Decimal(12, 2)
  lineTotal   Decimal         @db.Decimal(14, 2)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id              String         @id @default(cuid())
  orderId         String
  method          String
  amount          Decimal        @db.Decimal(14, 2)
  status          PaymentStatus  @default(UNPAID)
  paidAt          DateTime?
  transactionRef  String?
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paymentSourceId String?
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentSource   PaymentSource? @relation(fields: [paymentSourceId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Shipment {
  id                       String                  @id @default(cuid())
  orderId                  String                  @unique
  carrier                  String
  trackingCode             String?
  shippingStatus           String                  @default("NOT_CREATED")
  codAmount                Decimal?                @db.Decimal(14, 2)
  shippingFee              Decimal?                @db.Decimal(14, 2)
  note                     String?
  metadata                 Json?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  fromAddress              String?
  fromName                 String?
  fromPhone                String?
  lastSyncedAt             DateTime?
  partnerStatus            String?
  toAddress                String?
  toName                   String?
  toPhone                  String?
  weight                   Int?
  order                    Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingCaches           ShipmentTrackingCache[]
  codReconciliationStatus  String?                 @default("NOT_RECONCILED")
  codReconciledAt          DateTime?
  codReconciliationBatchId String?
  codReconciliationRowId   String?
  codReconciliationIssue   String?
  codReconciliationAmount  Int?
  ahamoveOrderId           String?
  ahamoveTrackingUrl       String?
  ahamoveStatus            String?
  ahamoveSubStatus         String?
  ahamoveRaw               Json?
  ahamoveShipment          AhamoveShipment?

  @@index([trackingCode])
  @@index([shippingStatus])
  @@index([partnerStatus])
  @@index([lastSyncedAt])
  @@index([ahamoveOrderId])
  @@index([ahamoveStatus])
}

model AhamoveShipment {
  id             String  @id @default(cuid())
  shipmentId     String  @unique
  orderId        String?
  ahamoveOrderId String  @unique

  serviceId   String?
  status      String?
  subStatus   String?
  trackingUrl String?
  sharedLink  String?

  codAmount   Decimal? @db.Decimal(14, 2)
  shippingFee Decimal? @db.Decimal(14, 2)

  fromName    String?
  fromPhone   String?
  fromAddress String?
  toName      String?
  toPhone     String?
  toAddress   String?

  path Json?
  raw  Json?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([serviceId])
  @@index([lastSyncedAt])
}

model AuditLog {
  id        String     @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime   @default(now())
  user      AdminUser? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
}

model StaffUser {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  username String? @unique
  email    String? @unique
  phone    String?
  address  String?
  note     String?

  // giữ lại để không vỡ code cũ, sau này bỏ dần
  role       String?
  branchId   String?
  branchName String?

  passwordHash          String  @default("")
  secondPasswordHash    String?
  secondPasswordEnabled Boolean @default(false)

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mainBranch Branch? @relation("StaffMainBranch", fields: [branchId], references: [id], onDelete: SetNull)

  roles             StaffUserRole[]
  branchPermissions StaffBranchPermission[]
  purchaseReceipts  PurchaseReceipt[]
  branchRoles       StaffBranchRole[]

  @@index([branchId])
  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model StaffUserRole {
  id        String   @id @default(cuid())
  staffId   String
  roleCode  String
  createdAt DateTime @default(now())

  staff StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, roleCode])
  @@index([roleCode])
}

model StaffBranchPermission {
  id       String @id @default(cuid())
  staffId  String
  branchId String

  canView             Boolean @default(true)
  canSell             Boolean @default(false)
  canViewOwnOrders    Boolean @default(false)
  canViewBranchOrders Boolean @default(false)
  canCreateOrder      Boolean @default(false)
  canApproveOrder     Boolean @default(false)
  canCancelOrder      Boolean @default(false)
  canHandleReturn     Boolean @default(false)

  canViewStock     Boolean @default(false)
  canManageStock   Boolean @default(false)
  canStocktake     Boolean @default(false)
  canTransferStock Boolean @default(false)
  canReceiveStock  Boolean @default(false)

  canViewCustomer Boolean @default(false)
  canEditCustomer Boolean @default(false)

  // Excel/import-export legacy flags for fast branch-scoped checks
  canExportProductExcel   Boolean @default(false)
  canImportProductExcel   Boolean @default(false)
  canExportOrderExcel     Boolean @default(false)
  canExportInventoryExcel Boolean @default(false)
  canExportCustomerExcel  Boolean @default(false)

  // Dynamic RBAC keys generated from role templates in admin UI.
  // Runtime authz reads this array first; boolean columns stay for backward compatibility.
  permissionKeys String[] @default([])

  canViewReport Boolean @default(false)
  canViewMoney  Boolean @default(false)

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([staffId, branchId])
  @@index([staffId])
  @@index([branchId])
}

model Branch {
  id                 String              @id
  name               String
  address            String?
  phone              String?
  email              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]

  importJobs             ImportJob[]
  purchaseReceipts       PurchaseReceipt[]
  stockTransfersFrom     StockTransfer[]          @relation("FromBranch")
  stockTransfersTo       StockTransfer[]          @relation("ToBranch")
  variantLocations       ProductVariantLocation[]
  staffUsers             StaffUser[]              @relation("StaffMainBranch")
  staffBranchPermissions StaffBranchPermission[]
  staffBranchRoles       StaffBranchRole[]
  promotions             Promotion[]
}

model ImportJob {
  id              String           @id @default(cuid())
  type            String
  fileName        String
  status          String
  totalRows       Int              @default(0)
  successRows     Int              @default(0)
  failedRows      Int              @default(0)
  errorFileUrl    String?
  defaultBranchId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  errors          ImportErrorLog[]
  defaultBranch   Branch?          @relation(fields: [defaultBranchId], references: [id])
}

model ImportErrorLog {
  id        String    @id @default(cuid())
  jobId     String
  rowNumber Int?
  message   String
  rawData   Json?
  createdAt DateTime  @default(now())
  job       ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
}

model AdministrativeProvince {
  code       String               @id
  name       String
  normalized String?
  isActive   Boolean              @default(true)
  sortOrder  Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  wards      AdministrativeWard[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([normalized])
}

model AdministrativeWard {
  code         String                 @id
  provinceCode String
  name         String
  normalized   String?
  isActive     Boolean                @default(true)
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  province     AdministrativeProvince @relation(fields: [provinceCode], references: [code], onDelete: Cascade)

  @@index([provinceCode])
  @@index([isActive])
  @@index([sortOrder])
  @@index([normalized])
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  code      String            @unique
  phone     String?
  email     String?
  address   String?
  note      String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  receipts  PurchaseReceipt[]

  @@index([name])
  @@index([isActive])
}

model PurchaseReceipt {
  id                      String                   @id @default(cuid())
  receiptCode             String                   @unique
  supplierId              String?
  branchId                String
  status                  PurchaseReceiptStatus    @default(DRAFT)
  note                    String?
  createdById             String?
  confirmedAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  adminUserId             String?
  adminUser               AdminUser?               @relation(fields: [adminUserId], references: [id])
  branch                  Branch                   @relation(fields: [branchId], references: [id])
  createdBy               StaffUser?               @relation(fields: [createdById], references: [id])
  supplier                Supplier?                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items                   PurchaseReceiptItem[]
  purchaseReceiptPayments PurchaseReceiptPayment[]

  @@index([supplierId])
  @@index([branchId])
  @@index([status])
}

model PurchaseReceiptItem {
  id          String          @id @default(cuid())
  receiptId   String
  productId   String?
  variantId   String
  sku         String
  productName String
  color       String?
  size        String?
  qty         Int
  unitCost    Decimal         @db.Decimal(14, 2)
  lineTotal   Decimal         @db.Decimal(14, 2)
  createdAt   DateTime        @default(now())
  product     Product?        @relation(fields: [productId], references: [id])
  receipt     PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  variant     ProductVariant  @relation(fields: [variantId], references: [id])

  @@index([receiptId])
  @@index([variantId])
}

model StockTransfer {
  id              String                  @id @default(cuid())
  transferCode    String                  @unique
  fromBranchId    String
  toBranchId      String
  note            String?
  status          TransferStatus          @default(DRAFT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  completedAt     DateTime?
  confirmedAt     DateTime?
  confirmedById   String?
  confirmedByName String?
  createdById     String?
  createdByName   String?
  direction       StockTransferDirection  @default(OUTBOUND_TO_BRANCH)
  sourceRefId     String?
  sourceType      StockTransferSourceType @default(MANUAL)
  notifications   BranchNotification[]
  fromBranch      Branch                  @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch        Branch                  @relation("ToBranch", fields: [toBranchId], references: [id])
  items           StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([direction, status, createdAt])
  @@index([sourceType, createdAt])
}

model StockTransferItem {
  id          String         @id @default(cuid())
  transferId  String
  variantId   String
  qty         Int
  createdAt   DateTime       @default(now())
  color       String?
  productName String?
  size        String?
  sku         String?
  transfer    StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([transferId])
  @@index([variantId])
}

model BranchNotification {
  id           String                 @id @default(cuid())
  branchId     String
  branchName   String?
  title        String
  message      String
  type         BranchNotificationType
  transferId   String?
  transferCode String?
  isRead       Boolean                @default(false)
  readAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transfer     StockTransfer?         @relation(fields: [transferId], references: [id])

  @@index([branchId, isRead, createdAt])
  @@index([transferId])
  @@index([type, createdAt])
}

model ShipmentTrackingCache {
  id             String   @id @default(cuid())
  shipmentId     String
  carrier        String
  trackingCode   String
  payloadJson    Json?
  normalizedJson Json
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([trackingCode])
  @@index([expiresAt])
}

model ShipmentCodAuthCode {
  id        String    @id @default(cuid())
  orderId   String
  code      String
  codAmount Int
  phone     String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orderId])
}

model PartialDeliveryRecord {
  id                   String                @id @default(cuid())
  orderId              String
  orderCode            String
  ghnTrackingCode      String?
  originalCod          Decimal               @db.Decimal(14, 2)
  adjustedCod          Decimal               @db.Decimal(14, 2)
  reason               String?
  approvedBy           String?
  approvedById         String?
  note                 String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  items                PartialDeliveryItem[]
  order                Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnStatus         String?               @default("PENDING_RETURN")
  returnReceivedAt     DateTime?
  returnReceivedBy     String?
  returnStockReceiptId String?
  returnStockNote      String?

  @@index([orderId])
  @@index([orderCode])
  @@index([ghnTrackingCode])
}

model PartialDeliveryItem {
  id           String                @id @default(cuid())
  recordId     String
  orderItemId  String?
  productName  String
  sku          String
  orderedQty   Int
  deliveredQty Int
  unitPrice    Decimal               @db.Decimal(14, 2)
  lineTotal    Decimal               @db.Decimal(14, 2)
  createdAt    DateTime              @default(now())
  record       PartialDeliveryRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model PaymentSource {
  id                      String                   @id @default(cuid())
  code                    String                   @unique
  name                    String
  type                    String
  branchId                String?
  isActive                Boolean                  @default(true)
  sortOrder               Int                      @default(0)
  note                    String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  payments                Payment[]
  purchaseReceiptPayments PurchaseReceiptPayment[]
}

model StockTransferAutoConfig {
  id                String    @id @default(cuid())
  isEnabled         Boolean   @default(false)
  runHour           Int       @default(9)
  runMinute         Int       @default(0)
  toBranchIds       String[]  @default([])
  categoryNames     String[]  @default([])
  branchMinTargets  Json?
  maxPerVariant     Int       @default(5)
  salesVelocityDays Int       @default(14)
  minSoldQty        Int       @default(0)
  lastRunAt         DateTime?
  lastRunDateKey    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum VariantStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  ADMIN
}

enum InventoryMovementType {
  IMPORT
  SALE
  CANCEL
  RETURN
  ADJUSTMENT
  RESERVE
  RELEASE
  TRANSFER_OUT
  TRANSFER_IN
  STOCKTAKE_ADJUST
}

enum SalesChannel {
  VN_WEB
  INTL_WEB
  FACEBOOK_MANUAL
  SHOWROOM
  POS
  OTHER
}

enum OrderStatus {
  NEW
  APPROVED
  PACKING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  PENDING_COD
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  PARTIAL
  FULFILLED
  RETURNED
}

enum PurchaseReceiptStatus {
  DRAFT
  PAYMENT_REQUESTED
  PARTIALLY_PAID
  PAID
  STOCK_IMPORTED
  COMPLETED
  CANCELLED
}

enum TransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
  PENDING
  CONFIRMED
  IN_TRANSIT
}

enum StockTransferDirection {
  OUTBOUND_TO_BRANCH
  INBOUND_FROM_BRANCH
}

enum StockTransferSourceType {
  AUTO
  REQUEST
  MANUAL
}

enum BranchNotificationType {
  TRANSFER_OUT_CREATED
  TRANSFER_OUT_CONFIRMED
  TRANSFER_IN_CREATED
  TRANSFER_IN_CONFIRMED
}

model GhnCodReconciliationBatch {
  id           String   @id @default(cuid())
  fileName     String
  transferCode String?
  transferDate String?
  totalRows    Int      @default(0)
  matchedRows  Int      @default(0)
  mismatchRows Int      @default(0)
  totalAmount  Int      @default(0)
  transferFee  Int      @default(0)
  netAmount    Int      @default(0)
  parserMode   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rows GhnCodReconciliationRow[]
}

model GhnCodReconciliationRow {
  id                         String   @id @default(cuid())
  batchId                    String
  orderId                    String?
  orderCode                  String?
  shipmentId                 String?
  ghnCode                    String
  customerOrderCode          String?
  ghnStatus                  String?
  codAmount                  Int      @default(0)
  serviceFee                 Int      @default(0)
  totalReconcileAmount       Int      @default(0)
  reconciliationStatus       String
  issues                     String[] @default([])
  partialDeliveryRecordId    String?
  partialDeliveryAdjustedCod Int?
  partialReturnReceived      Boolean?
  createdAt                  DateTime @default(now())

  batch GhnCodReconciliationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([orderId])
  @@index([shipmentId])
  @@index([ghnCode])
}

model StocktakeSession {
  id       String  @id @default(cuid())
  branchId String
  name     String
  note     String?
  status   String  @default("DRAFT")

  createdById String?
  startedAt   DateTime?
  finishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workers    StocktakeWorker[]
  scanEvents StocktakeScanEvent[]
  areas      StocktakeArea[]

  @@index([branchId])
  @@index([status])
}

model StocktakeWorker {
  id         String  @id @default(cuid())
  sessionId  String
  name       String
  userId     String?
  zone       String?
  deviceName String?
  isActive   Boolean @default(true)

  status     String    @default("IN_PROGRESS")
  startedAt  DateTime? @default(now())
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session    StocktakeSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scanEvents StocktakeScanEvent[]

  @@index([sessionId])
}

model StocktakeScanEvent {
  id        String  @id @default(cuid())
  sessionId String
  workerId  String?
  branchId  String

  variantId    String?
  sku          String
  barcode      String?
  qtyDelta     Int     @default(1)
  zone         String?
  locationCode String?

  status String  @default("OK")
  note   String?

  createdAt DateTime @default(now())

  session StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  worker  StocktakeWorker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([workerId])
  @@index([variantId])
  @@index([sku])
}

model WarehouseMap {
  id       String  @id @default(cuid())
  branchId String
  name     String
  code     String  @unique
  note     String?
  width    Int     @default(1200)
  height   Int     @default(800)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  racks  WarehouseRack[]
  floors WarehouseFloor[]
  zones  WarehouseZone[]
  doors  WarehouseDoor[]

  @@index([branchId])
  @@index([code])
}

model WarehouseRack {
  id       String @id @default(cuid())
  mapId    String
  branchId String

  code String @unique
  name String

  zone   String
  aisle  String
  rackNo String

  floors Int @default(5)

  x        Int @default(0)
  y        Int @default(0)
  w        Int @default(120)
  h        Int @default(260)
  rotation Int @default(0)

  status   String  @default("PENDING") // PENDING, IN_PROGRESS, FINISHED, MISMATCH
  note     String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map              WarehouseMap             @relation(fields: [mapId], references: [id], onDelete: Cascade)
  shelves          WarehouseShelf[]
  variantLocations ProductVariantLocation[]

  @@index([mapId])
  @@index([branchId])
  @@index([zone])
  @@index([status])
}

model WarehouseShelf {
  id     String @id @default(cuid())
  rackId String

  code    String @unique
  floorNo Int

  label    String?
  capacity Int     @default(0)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rack             WarehouseRack            @relation(fields: [rackId], references: [id], onDelete: Cascade)
  variantLocations ProductVariantLocation[]

  @@index([rackId])
}

model ProductVariantLocation {
  id String @id @default(cuid())

  variantId String
  branchId  String?
  areaId    String?
  rackId    String?
  shelfId   String?

  minQty   Int?
  maxQty   Int?
  note     String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch    Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  area      StocktakeArea?  @relation(fields: [areaId], references: [id], onDelete: SetNull)
  rack      WarehouseRack?  @relation(fields: [rackId], references: [id], onDelete: SetNull)
  shelf     WarehouseShelf? @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  isPrimary Boolean         @default(false)

  @@index([variantId])
  @@index([branchId])
  @@index([areaId])
  @@index([rackId])
  @@index([shelfId])
}

model StocktakeArea {
  id        String  @id @default(cuid())
  sessionId String
  branchId  String
  mapId     String?

  scopeType String // MAP | AISLE | RACK
  aisle     String?
  rackId    String?
  rackCode  String?
  label     String

  status String @default("PENDING")

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  session          StocktakeSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variantLocations ProductVariantLocation[]

  @@index([sessionId])
  @@index([branchId])
  @@index([mapId])
  @@index([scopeType])
  @@index([status])
}

model WarehouseFloor {
  id    String  @id @default(cuid())
  mapId String
  name  String
  level Int     @default(1)
  note  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map   WarehouseMap    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  zones WarehouseZone[]
  doors WarehouseDoor[]

  @@index([mapId])
}

model WarehouseZone {
  id      String @id @default(cuid())
  mapId   String
  floorId String
  name    String
  type    String @default("STORAGE")

  x      Float   @default(0)
  y      Float   @default(0)
  width  Float   @default(500)
  height Float   @default(300)
  color  String?
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map   WarehouseMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  floor WarehouseFloor @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@index([floorId])
  @@index([type])
}

model WarehouseDoor {
  id      String @id @default(cuid())
  mapId   String
  floorId String
  name    String @default("Cửa kho")
  side    String @default("BOTTOM")
  x       Float  @default(0)
  y       Float  @default(0)
  width   Float  @default(180)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map   WarehouseMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  floor WarehouseFloor @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@index([floorId])
}

// ===== STOCKTAKE SNAPSHOT + REALTIME COUNT PATCH =====
model StocktakeSnapshot {
  id          String @id @default(cuid())
  sessionId   String
  branchId    String
  variantId   String
  snapshotQty Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, variantId, branchId])
  @@index([sessionId])
  @@index([branchId])
  @@index([variantId])
}

model StocktakeCount {
  id        String  @id @default(cuid())
  sessionId String
  workerId  String?
  branchId  String
  variantId String?
  sku       String

  countedQty Int @default(0)
  eventCount Int @default(0)

  zone         String?
  areaId       String?
  rackId       String?
  rackCode     String?
  locationCode String?
  status       String  @default("OK")

  lastScannedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([sessionId, branchId, sku, workerId])
  @@index([sessionId])
  @@index([workerId])
  @@index([branchId])
  @@index([variantId])
  @@index([areaId])
  @@index([rackId])
}

model ReturnExchange {
  id                         String               @id @default(cuid())
  code                       String               @unique
  originalOrderId            String
  originalBranchId           String?
  originalStaffId            String?
  originalStaffName          String?
  handledByStaffId           String?
  handledByStaffName         String?
  handledAtBranchId          String?
  returnReceiveBranchId      String?
  exchangeIssueBranchId      String?
  type                       String
  status                     String               @default("DRAFT")
  returnAmount               Decimal              @default(0) @db.Decimal(14, 2)
  exchangeAmount             Decimal              @default(0) @db.Decimal(14, 2)
  differenceAmount           Decimal              @default(0) @db.Decimal(14, 2)
  refundAmount               Decimal              @default(0) @db.Decimal(14, 2)
  extraChargeAmount          Decimal              @default(0) @db.Decimal(14, 2)
  refundPaymentSourceId      String?
  extraChargePaymentSourceId String?
  note                       String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  items                      ReturnExchangeItem[]
  cashVouchers               CashVoucher[]

  @@index([originalOrderId])
  @@index([originalBranchId])
  @@index([handledAtBranchId])
  @@index([returnReceiveBranchId])
  @@index([status])
  @@index([createdAt])
}

model ReturnExchangeItem {
  id               String         @id @default(cuid())
  returnExchangeId String
  itemType         String         @default("RETURN")
  orderItemId      String?
  variantId        String?
  sku              String?
  productName      String?
  qty              Int
  unitPrice        Decimal        @default(0) @db.Decimal(14, 2)
  refundPrice      Decimal        @default(0) @db.Decimal(14, 2)
  lineTotal        Decimal        @default(0) @db.Decimal(14, 2)
  reason           String?
  returnExchange   ReturnExchange @relation(fields: [returnExchangeId], references: [id], onDelete: Cascade)

  @@index([returnExchangeId])
  @@index([itemType])
  @@index([variantId])
}

model CashVoucher {
  id              String          @id @default(cuid())
  code            String          @unique
  direction       String
  voucherType     String
  amount          Decimal         @default(0) @db.Decimal(14, 2)
  paymentSourceId String?
  branchId        String?
  staffId         String?
  staffName       String?
  customerName    String?
  customerPhone   String?
  refType         String?
  refId           String?
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  returnExchange  ReturnExchange? @relation(fields: [refId], references: [id])

  @@index([direction])
  @@index([voucherType])
  @@index([paymentSourceId])
  @@index([branchId])
  @@index([refType, refId])
  @@index([createdAt])
}

enum PromotionType {
  PRODUCT_DISCOUNT
  ORDER_DISCOUNT
}

enum PromotionDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum PromotionStatus {
  ACTIVE
  INACTIVE
}

model Promotion {
  id     String          @id @default(cuid())
  name   String
  type   PromotionType
  status PromotionStatus @default(ACTIVE)

  discountType  PromotionDiscountType
  discountValue Decimal               @db.Decimal(18, 2)

  minOrderAmount Decimal? @db.Decimal(18, 2)

  branchId     String?
  salesChannel SalesChannel?

  startAt DateTime?
  endAt   DateTime?

  priority Int     @default(0)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products PromotionProduct[]

  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([status])
  @@index([type])
  @@index([branchId])
  @@index([salesChannel])
}

model PromotionProduct {
  id          String @id @default(cuid())
  promotionId String
  productId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@index([productId])
}

model PurchaseReceiptPayment {
  id              String          @id @default(cuid())
  receiptId       String
  paymentSourceId String?
  amount          Decimal         @default(0) @db.Decimal(14, 2)
  note            String?
  paidById        String?
  paidByName      String?
  paidAt          DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  receipt         PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  paymentSource   PaymentSource?  @relation(fields: [paymentSourceId], references: [id])

  @@index([receiptId])
  @@index([paymentSourceId])
  @@index([paidAt])
}

model StaffBranchRole {
  id       String @id @default(cuid())
  staffId  String
  branchId String
  roleCode String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([staffId, branchId])
  @@index([staffId])
  @@index([branchId])
}
