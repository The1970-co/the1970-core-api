generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id                 String              @id @default(cuid())
  fullName           String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(STAFF)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  totpEnabled        Boolean             @default(false)
  totpSecret         String?
  auditLogs          AuditLog[]
  inventoryMovements InventoryMovement[]
  purchaseReceipts   PurchaseReceipt[]
}

model Product {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  category             String?
  categoryId           String?
  productType          String?
  brand                String?
  weight               Float?
  imageUrl             String?
  description          String?
  status               ProductStatus         @default(DRAFT)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  categoryRel          Category?             @relation(fields: [categoryId], references: [id])
  variants             ProductVariant[]
  purchaseReceiptItems PurchaseReceiptItem[]
  promotionProducts    PromotionProduct[]

  @@index([categoryId])
}

model ProductVariant {
  id                   String                   @id @default(cuid())
  productId            String
  sku                  String                   @unique
  color                String?
  size                 String?
  price                Decimal                  @db.Decimal(14, 2)
  compareAtPrice       Decimal?                 @db.Decimal(14, 2)
  costPrice            Decimal?                 @db.Decimal(14, 2)
  imageUrl             String?
  status               VariantStatus            @default(ACTIVE)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  inventoryItems       InventoryItem[]
  movements            InventoryMovement[]
  orderItems           OrderItem[]
  product              Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseReceiptItems PurchaseReceiptItem[]
  stockTransferItems   StockTransferItem[]
  locations            ProductVariantLocation[]
  promotionProducts    PromotionProduct[]
  variantName          String?
}

model InventoryItem {
  id           String         @id @default(cuid())
  variantId    String
  branchId     String
  availableQty Int            @default(0)
  reservedQty  Int            @default(0)
  incomingQty  Int            @default(0)
  updatedAt    DateTime       @updatedAt
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, branchId])
  @@index([branchId])
  @@index([variantId])
}

model InventoryMovement {
  id String @id @default(cuid())

  variantId String
  branchId  String

  type InventoryMovementType
  qty  Int

  beforeQty Int?
  afterQty  Int?

  note    String?
  refType String?
  refId   String?

  createdById String?
  createdAt   DateTime @default(now())

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy AdminUser?     @relation(fields: [createdById], references: [id])

  @@index([variantId])
  @@index([branchId])
  @@index([type])
  @@index([refType, refId])
  @@index([createdAt])
}

model Customer {
  id                     String            @id @default(cuid())
  legacyCode             String?
  fullName               String
  phone                  String?
  email                  String?
  source                 String?
  customerGroup          String?
  gender                 String?
  birthDate              DateTime?
  points                 Int               @default(0)
  totalOrders            Int               @default(0)
  totalSpent             Decimal           @default(0) @db.Decimal(14, 2)
  lastOrderAt            DateTime?
  defaultDiscountPercent Decimal?          @db.Decimal(5, 2)
  pricePolicyName        String?
  customerNote           String?
  lastImportedAt         DateTime?
  lastImportedSource     String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  addresses              CustomerAddress[]
  orders                 Order[]

  @@index([phone])
  @@index([email])
  @@index([legacyCode])
  @@index([customerGroup])
}

model CustomerAddress {
  id            String   @id @default(cuid())
  customerId    String
  label         String?
  recipientName String?
  phone         String?
  email         String?
  addressLine1  String
  addressLine2  String?
  ward          String?
  district      String?
  city          String?
  province      String?
  country       String?  @default("Vietnam")
  postalCode    String?
  isDefault     Boolean  @default(false)
  ghnDistrictId Int?
  ghnWardCode   String?
  ghnWardIdV2   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([customerId])
  @@index([province])
  @@index([ward])
  @@index([ghnDistrictId])
  @@index([ghnWardCode])
}

model Order {
  id                      String                  @id @default(cuid())
  orderCode               String                  @unique
  salesChannel            SalesChannel
  customerId              String?
  customerName            String?
  customerPhone           String?
  branchId                String?
  currency                String                  @default("VND")
  totalAmount             Decimal                 @default(0) @db.Decimal(14, 2)
  discountAmount          Decimal                 @default(0) @db.Decimal(14, 2)
  shippingFee             Decimal                 @default(0) @db.Decimal(14, 2)
  finalAmount             Decimal                 @default(0) @db.Decimal(14, 2)
  paymentStatus           PaymentStatus           @default(UNPAID)
  fulfillmentStatus       FulfillmentStatus       @default(UNFULFILLED)
  status                  OrderStatus             @default(NEW)
  note                    String?
  source                  String?
  customerAddressId       String?
  shippingRecipientName   String?
  shippingPhone           String?
  shippingEmail           String?
  shippingAddressLabel    String?
  shippingAddressLine1    String?
  shippingAddressLine2    String?
  shippingWard            String?
  shippingDistrict        String?
  shippingCity            String?
  shippingProvince        String?
  shippingCountry         String?
  shippingPostalCode      String?
  shippingGhnDistrictId   Int?
  shippingGhnWardCode     String?
  shippingGhnWardIdV2     String?
  billingRecipientName    String?
  billingPhone            String?
  billingEmail            String?
  billingAddressLabel     String?
  billingAddressLine1     String?
  billingAddressLine2     String?
  billingWard             String?
  billingDistrict         String?
  billingCity             String?
  billingProvince         String?
  billingCountry          String?
  billingPostalCode       String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  createdByStaffId        String?
  createdByStaffName      String?
  assignedStaffId         String?
  assignedStaffName       String?
  soldAt                  DateTime                @default(now())
  isPartialDelivery       Boolean                 @default(false)
  partialReason           String?
  customerAddress         CustomerAddress?        @relation(fields: [customerAddressId], references: [id])
  customer                Customer?               @relation(fields: [customerId], references: [id])
  items                   OrderItem[]
  partialDeliveries       PartialDeliveryRecord[] @relation("PartialDeliverySourceOrder")
  returnPartialDeliveries PartialDeliveryRecord[] @relation("PartialDeliveryReturnOrder")
  payments                Payment[]
  shipment                Shipment?

  @@index([customerPhone])
  @@index([branchId])
  @@index([customerId])
  @@index([customerAddressId])
  @@index([shippingProvince])
  @@index([shippingWard])
  @@index([shippingGhnDistrictId])
  @@index([shippingGhnWardCode])
  @@index([status])
  @@index([createdByStaffId])
  @@index([soldAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  variantId   String?
  sku         String
  productName String
  color       String?
  size        String?
  qty         Int
  unitPrice   Decimal         @db.Decimal(12, 2)
  lineTotal   Decimal         @db.Decimal(14, 2)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id              String         @id @default(cuid())
  orderId         String
  method          String
  amount          Decimal        @db.Decimal(14, 2)
  status          PaymentStatus  @default(UNPAID)
  paidAt          DateTime?
  transactionRef  String?
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paymentSourceId String?
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentSource   PaymentSource? @relation(fields: [paymentSourceId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Shipment {
  id                       String                  @id @default(cuid())
  orderId                  String                  @unique
  carrier                  String
  trackingCode             String?
  shippingStatus           String                  @default("NOT_CREATED")
  codAmount                Decimal?                @db.Decimal(14, 2)
  shippingFee              Decimal?                @db.Decimal(14, 2)
  note                     String?
  metadata                 Json?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  fromAddress              String?
  fromName                 String?
  fromPhone                String?
  lastSyncedAt             DateTime?
  partnerStatus            String?
  toAddress                String?
  toName                   String?
  toPhone                  String?
  weight                   Int?
  order                    Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingCaches           ShipmentTrackingCache[]
  trackingEvents           ShipmentTimelineEvent[]
  codReconciliationStatus  String?                 @default("NOT_RECONCILED")
  codReconciledAt          DateTime?
  codReconciliationBatchId String?
  codReconciliationRowId   String?
  codReconciliationIssue   String?
  codReconciliationAmount  Int?
  ahamoveOrderId           String?
  ahamoveTrackingUrl       String?
  ahamoveStatus            String?
  ahamoveSubStatus         String?
  ahamoveRaw               Json?
  ahamoveShipment          AhamoveShipment?

  @@index([trackingCode])
  @@index([shippingStatus])
  @@index([partnerStatus])
  @@index([lastSyncedAt])
  @@index([ahamoveOrderId])
  @@index([ahamoveStatus])
}

model ShipmentTimelineEvent {
  id            String   @id @default(cuid())
  shipmentId    String
  orderId       String?
  carrier       String?
  trackingCode  String?
  status        String
  partnerStatus String?
  title         String
  description   String?
  driverName    String?
  driverPhone   String?
  driverPlate   String?
  eta           String?
  locationText  String?
  raw           Json?
  source        String   @default("system")
  eventTime     DateTime @default(now())
  createdAt     DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([orderId])
  @@index([carrier])
  @@index([status])
  @@index([eventTime])
}

model AhamoveShipment {
  id             String  @id @default(cuid())
  shipmentId     String  @unique
  orderId        String?
  ahamoveOrderId String  @unique

  serviceId   String?
  status      String?
  subStatus   String?
  trackingUrl String?
  sharedLink  String?

  codAmount   Decimal? @db.Decimal(14, 2)
  shippingFee Decimal? @db.Decimal(14, 2)

  fromName    String?
  fromPhone   String?
  fromAddress String?
  toName      String?
  toPhone     String?
  toAddress   String?

  path Json?
  raw  Json?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([serviceId])
  @@index([lastSyncedAt])
}

model AuditLog {
  id        String     @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime   @default(now())
  user      AdminUser? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
}

model StaffUser {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  username String? @unique
  email    String? @unique
  phone    String?
  address  String?
  note     String?

  // giữ lại để không vỡ code cũ, sau này bỏ dần
  role       String?
  branchId   String?
  branchName String?

  passwordHash          String  @default("")
  secondPasswordHash    String?
  secondPasswordEnabled Boolean @default(false)

  isActive       Boolean   @default(true)
  sessionVersion Int       @default(1)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  mainBranch Branch? @relation("StaffMainBranch", fields: [branchId], references: [id], onDelete: SetNull)

  roles             StaffUserRole[]
  branchPermissions StaffBranchPermission[]
  purchaseReceipts  PurchaseReceipt[]
  branchRoles       StaffBranchRole[]
  sessions          StaffSession[]
  departments       StaffDepartment[]

  @@index([branchId])
  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model StaffSession {
  id               String    @id @default(cuid())
  staffId          String
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  sessionVersion   Int
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  staff StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model StaffUserRole {
  id        String   @id @default(cuid())
  staffId   String
  roleCode  String
  createdAt DateTime @default(now())

  staff StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, roleCode])
  @@index([roleCode])
}

model StaffRoleTemplate {
  id          String   @id @default(cuid())
  roleCode    String   @unique
  name        String
  scope       String   @default("ONE_BRANCH")
  description String   @default("")
  note        String   @default("")
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roleCode])
}

model StaffBranchPermission {
  id       String @id @default(cuid())
  staffId  String
  branchId String

  canView             Boolean @default(true)
  canSell             Boolean @default(false)
  canViewOwnOrders    Boolean @default(false)
  canViewBranchOrders Boolean @default(false)
  canCreateOrder      Boolean @default(false)
  canApproveOrder     Boolean @default(false)
  canCancelOrder      Boolean @default(false)
  canHandleReturn     Boolean @default(false)

  canViewStock     Boolean @default(false)
  canManageStock   Boolean @default(false)
  canStocktake     Boolean @default(false)
  canTransferStock Boolean @default(false)
  canReceiveStock  Boolean @default(false)

  canViewCustomer Boolean @default(false)
  canEditCustomer Boolean @default(false)

  // Excel/import-export legacy flags for fast branch-scoped checks
  canExportProductExcel   Boolean @default(false)
  canImportProductExcel   Boolean @default(false)
  canExportOrderExcel     Boolean @default(false)
  canExportInventoryExcel Boolean @default(false)
  canExportCustomerExcel  Boolean @default(false)

  // Dynamic RBAC keys generated from role templates in admin UI.
  // Runtime authz reads this array first; boolean columns stay for backward compatibility.
  permissionKeys       String[] @default([])
  extraPermissionKeys  String[] @default([])
  deniedPermissionKeys String[] @default([])

  canViewReport Boolean @default(false)
  canViewMoney  Boolean @default(false)

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([staffId, branchId])
  @@index([staffId])
  @@index([branchId])
}

model Branch {
  id                 String              @id
  name               String
  address            String?
  phone              String?
  email              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]

  importJobs             ImportJob[]
  purchaseReceipts       PurchaseReceipt[]
  stockTransfersFrom     StockTransfer[]          @relation("FromBranch")
  stockTransfersTo       StockTransfer[]          @relation("ToBranch")
  variantLocations       ProductVariantLocation[]
  staffUsers             StaffUser[]              @relation("StaffMainBranch")
  staffBranchPermissions StaffBranchPermission[]
  staffBranchRoles       StaffBranchRole[]
  promotions             Promotion[]
}

model ImportJob {
  id              String           @id @default(cuid())
  type            String
  fileName        String
  status          String
  totalRows       Int              @default(0)
  successRows     Int              @default(0)
  failedRows      Int              @default(0)
  errorFileUrl    String?
  defaultBranchId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  errors          ImportErrorLog[]
  defaultBranch   Branch?          @relation(fields: [defaultBranchId], references: [id])
}

model ImportErrorLog {
  id        String    @id @default(cuid())
  jobId     String
  rowNumber Int?
  message   String
  rawData   Json?
  createdAt DateTime  @default(now())
  job       ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
}

model AdministrativeProvince {
  code       String               @id
  name       String
  normalized String?
  isActive   Boolean              @default(true)
  sortOrder  Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  wards      AdministrativeWard[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([normalized])
}

model AdministrativeWard {
  code         String                 @id
  provinceCode String
  name         String
  normalized   String?
  isActive     Boolean                @default(true)
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  province     AdministrativeProvince @relation(fields: [provinceCode], references: [code], onDelete: Cascade)

  @@index([provinceCode])
  @@index([isActive])
  @@index([sortOrder])
  @@index([normalized])
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  code      String            @unique
  phone     String?
  email     String?
  address   String?
  note      String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  receipts  PurchaseReceipt[]

  @@index([name])
  @@index([isActive])
}

model PurchaseReceipt {
  id                      String                   @id @default(cuid())
  receiptCode             String                   @unique
  supplierId              String?
  branchId                String
  status                  PurchaseReceiptStatus    @default(DRAFT)
  note                    String?
  createdById             String?
  confirmedAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  adminUserId             String?
  adminUser               AdminUser?               @relation(fields: [adminUserId], references: [id])
  branch                  Branch                   @relation(fields: [branchId], references: [id])
  createdBy               StaffUser?               @relation(fields: [createdById], references: [id])
  supplier                Supplier?                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items                   PurchaseReceiptItem[]
  purchaseReceiptPayments PurchaseReceiptPayment[]

  @@index([supplierId])
  @@index([branchId])
  @@index([status])
}

model PurchaseReceiptItem {
  id          String          @id @default(cuid())
  receiptId   String
  productId   String?
  variantId   String
  sku         String
  productName String
  color       String?
  size        String?
  qty         Int
  unitCost    Decimal         @db.Decimal(14, 2)
  lineTotal   Decimal         @db.Decimal(14, 2)
  createdAt   DateTime        @default(now())
  product     Product?        @relation(fields: [productId], references: [id])
  receipt     PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  variant     ProductVariant  @relation(fields: [variantId], references: [id])

  @@index([receiptId])
  @@index([variantId])
}

model StockTransfer {
  id              String                  @id @default(cuid())
  transferCode    String                  @unique
  fromBranchId    String
  toBranchId      String
  note            String?
  status          TransferStatus          @default(DRAFT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  completedAt     DateTime?
  confirmedAt     DateTime?
  confirmedById   String?
  confirmedByName String?
  createdById     String?
  createdByName   String?
  direction       StockTransferDirection  @default(OUTBOUND_TO_BRANCH)
  sourceRefId     String?
  sourceType      StockTransferSourceType @default(MANUAL)
  notifications   BranchNotification[]
  fromBranch      Branch                  @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch        Branch                  @relation("ToBranch", fields: [toBranchId], references: [id])
  items           StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([direction, status, createdAt])
  @@index([sourceType, createdAt])
}

model StockTransferItem {
  id          String         @id @default(cuid())
  transferId  String
  variantId   String
  qty         Int
  createdAt   DateTime       @default(now())
  color       String?
  productName String?
  size        String?
  sku         String?
  transfer    StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([transferId])
  @@index([variantId])
}

model BranchNotification {
  id           String                 @id @default(cuid())
  branchId     String
  branchName   String?
  title        String
  message      String
  type         BranchNotificationType
  transferId   String?
  transferCode String?
  isRead       Boolean                @default(false)
  readAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transfer     StockTransfer?         @relation(fields: [transferId], references: [id])

  @@index([branchId, isRead, createdAt])
  @@index([transferId])
  @@index([type, createdAt])
}

model ShipmentTrackingCache {
  id             String   @id @default(cuid())
  shipmentId     String
  carrier        String
  trackingCode   String
  payloadJson    Json?
  normalizedJson Json
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([trackingCode])
  @@index([expiresAt])
}

model ShipmentCodAuthCode {
  id        String    @id @default(cuid())
  orderId   String
  code      String
  codAmount Int
  phone     String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orderId])
}

model PartialDeliveryRecord {
  id              String                @id @default(cuid())
  code            String?               @unique
  orderId         String
  orderCode       String
  ghnTrackingCode String?
  originalCod     Decimal               @db.Decimal(14, 2)
  adjustedCod     Decimal               @db.Decimal(14, 2)
  shippingFee     Decimal               @default(0) @db.Decimal(14, 2)
  reason          String?
  approvedBy      String?
  approvedById    String?
  note            String?
  handledAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           PartialDeliveryItem[]
  order           Order                 @relation("PartialDeliverySourceOrder", fields: [orderId], references: [id], onDelete: Cascade)

  returnOrderId        String?
  returnOrderCode      String?
  returnTrackingCode   String?
  returnOrder          Order?    @relation("PartialDeliveryReturnOrder", fields: [returnOrderId], references: [id], onDelete: SetNull)
  returnStatus         String?   @default("PENDING_RETURN")
  returnReceivedAt     DateTime?
  returnReceivedBy     String?
  returnStockReceiptId String?
  returnStockNote      String?

  @@index([orderId])
  @@index([orderCode])
  @@index([ghnTrackingCode])
  @@index([returnOrderId])
  @@index([returnOrderCode])
  @@index([returnTrackingCode])
  @@index([returnStatus])
}

model PartialDeliveryItem {
  id           String                @id @default(cuid())
  recordId     String
  orderItemId  String?
  variantId    String?
  productName  String
  sku          String
  color        String?
  size         String?
  orderedQty   Int
  deliveredQty Int
  returnedQty  Int                   @default(0)
  actionType   String                @default("KEPT")
  unitPrice    Decimal               @db.Decimal(14, 2)
  lineTotal    Decimal               @db.Decimal(14, 2)
