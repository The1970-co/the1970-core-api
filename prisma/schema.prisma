  @@index([syncType])
  @@index([status])
  @@index([startedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Omni Inbox / Meta Messaging
// Event-driven inbox: Meta webhook -> DB -> SSE realtime.
// ─────────────────────────────────────────────────────────────────────────────

enum OmniChannel {
  FACEBOOK
  INSTAGRAM
  SYSTEM
}

enum OmniConversationStatus {
  OPEN
  PENDING
  PROCESSING
  CLOSED
  SPAM
}

enum OmniMessageDirection {
  IN
  OUT
  SYSTEM
}

enum OmniMessageType {
  TEXT
  IMAGE
  FILE
  STICKER
  UNKNOWN
}

model OmniInboxPage {
  id             String      @id @default(cuid())
  channel        OmniChannel
  providerPageId String      @unique
  pageName       String
  accessTokenEnc String?
  isActive       Boolean     @default(true)
  lastWebhookAt  DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversations OmniConversation[]

  @@index([channel, isActive])
}

model OmniCustomer {
  id             String   @id @default(cuid())
  providerUserId String?  @unique
  name           String
  avatarUrl      String?
  phone          String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversations OmniConversation[]

  @@index([phone])
  @@index([name])
}

model OmniConversation {
  id               String      @id @default(cuid())
  channel          OmniChannel
  providerThreadId String      @unique

  pageId String?
  page   OmniInboxPage? @relation(fields: [pageId], references: [id])

  customerId String?
  customer   OmniCustomer? @relation(fields: [customerId], references: [id])

  status          OmniConversationStatus @default(OPEN)
  assigneeId      String?
  assigneeName    String?
  branchId        String?
  lastMessageText String?
  lastMessageAt   DateTime?
  unreadCount     Int                    @default(0)

  lockedById String?
  lockedAt   DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages OmniMessage[]
  tags     OmniConversationTag[]
  notes    OmniConversationNote[]

  @@index([status, updatedAt])
  @@index([assigneeId, status])
  @@index([branchId, status])
  @@index([lastMessageAt])
}

model OmniMessage {
  id String @id @default(cuid())

  conversationId String
  conversation   OmniConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  providerMessageId String?              @unique
  direction         OmniMessageDirection
  type              OmniMessageType      @default(TEXT)
  text              String?
  attachmentUrl     String?
  senderId          String?
  senderName        String?
  sentAt            DateTime
  createdAt         DateTime             @default(now())

  @@index([conversationId, sentAt])
  @@index([direction, sentAt])
}

model OmniConversationTag {
  id String @id @default(cuid())

  conversationId String
  conversation   OmniConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  tag String

  @@unique([conversationId, tag])
  @@index([tag])
}

model OmniConversationNote {
  id String @id @default(cuid())

  conversationId String
  conversation   OmniConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  staffId   String?
  staffName String?
  note      String
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model LocalDeliveryReconciliation {
  id              String    @id
  code            String?   @unique
  orderId         String
  shipmentId      String?
  branchId        String?
  carrier         String?
  trackingCode    String?
  status          String    @default("DRAFT")
  codAmount       Decimal   @default(0) @db.Decimal(18, 2)
  shippingFee     Decimal   @default(0) @db.Decimal(18, 2)
  paidAmount      Decimal   @default(0) @db.Decimal(18, 2)
  paymentRows     Json?
  note            String?
  createdById     String?
  createdByName   String?
  confirmedById   String?
  confirmedByName String?
  paidById        String?
  paidByName      String?
  cancelledById   String?
  cancelledByName String?
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @db.Timestamp(6)
  confirmedAt     DateTime? @db.Timestamp(6)
  paidAt          DateTime? @db.Timestamp(6)
  cancelledAt     DateTime? @db.Timestamp(6)

  @@index([branchId, createdAt], map: "LocalDeliveryReconciliation_branch_createdAt_idx")
  @@index([orderId, status, createdAt], map: "LocalDeliveryReconciliation_order_status_idx")
  @@index([shipmentId, status, createdAt], map: "LocalDeliveryReconciliation_shipment_status_idx")
}

model SystemSetting {
  key       String   @id
  value     Json
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MobilePushToken {
  id         String   @id @default(cuid())
  userId     String?
  staffId    String?
  branchId   String?
  platform   String
  provider   String
  token      String   @unique
  deviceId   String?
  appVersion String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([staffId])
  @@index([branchId])
  @@index([platform])
  @@index([provider])
  @@index([isActive])
}
